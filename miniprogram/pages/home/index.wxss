/* pages/home/index.wxss */

/* 根容器 */
.page-root {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
}

/* 全屏背景图 */
.bg-image {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

/* 半透明遮罩 */
.bg-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.18);
  z-index: 1;
}

/* 右下角换封面小图标（悬浮，半透明） */
.change-cover-fab {
  position: fixed;
  right: 28rpx;
  bottom: calc(env(safe-area-inset-bottom) + 180rpx);
  z-index: 10;
  width: 64rpx;
  height: 64rpx;
  background: rgba(0, 0, 0, 0.28);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-fab-icon {
  font-size: 32rpx;
  line-height: 1;
}

.cover-fab-loading {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  line-height: 1;
}

/* 情侣头部区（顶部） */
.top-area {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 2;
  padding: 0 28rpx;
  box-sizing: border-box;
}

/* 底部卡片区（固定在屏幕最底端，tabBar 上方） */
.cards-bottom {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: calc(env(safe-area-inset-bottom) + 120rpx);
  z-index: 2;
}

/* ── 情侣头部（无白框，透明背景） ── */
.couple-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 10rpx 30rpx;
}

.couple-user {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}

.avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: #f5f5f5;
  border: 4rpx solid rgba(255,255,255,0.8);
}

.couple-name {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
  text-shadow: 0 1rpx 6rpx rgba(0,0,0,0.4);
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.couple-id {
  font-size: 18rpx;
  color: rgba(255,255,255,0.65);
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.4);
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 中间连接区 */
.couple-center {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  padding: 0 10rpx;
}

/* 上弧线：border-top + border-radius 模拟弯曲 */
.arc-top {
  width: 100%;
  height: 36rpx;
  border-top: 4rpx solid #ff4d88;
  border-left: 4rpx solid transparent;
  border-right: 4rpx solid transparent;
  border-radius: 50% 50% 0 0 / 100% 100% 0 0;
  box-sizing: border-box;
}

/* 下弧线：border-bottom + border-radius */
.arc-bottom {
  width: 100%;
  height: 36rpx;
  border-bottom: 4rpx solid #ff4d88;
  border-left: 4rpx solid transparent;
  border-right: 4rpx solid transparent;
  border-radius: 0 0 50% 50% / 0 0 100% 100%;
  box-sizing: border-box;
}

/* 中间文字区 */
.center-text-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 0;
}

.heart-icon { font-size: 40rpx; }

.together-days {
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
  text-shadow: 0 1rpx 6rpx rgba(0,0,0,0.4);
  text-decoration: underline;
  text-underline-offset: 4rpx;
}

.together-days-tap {
  color: rgba(255,255,255,0.7);
  text-decoration: underline;
}

/* ── 卡片（半透明） ── */
.card {
  background: rgba(255, 255, 255, 0.88);
  border-radius: 24rpx;
  padding: 44rpx 40rpx;
  margin-bottom: 28rpx;
  backdrop-filter: blur(10px);
  flex-shrink: 0;
}

.section-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

/* 纪念日 */
.anniv-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(0,0,0,0.06);
}

.anniv-item:last-child { border-bottom: none; }

.anniv-title {
  font-size: 30rpx;
  color: #333;
}

.anniv-days { font-size: 26rpx; }
.anniv-days.past  { color: #ff7eb3; }
.anniv-days.future { color: #6cb0ff; }

/* 留言 */
.msg-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(0,0,0,0.06);
}

.msg-item:last-child { border-bottom: none; }

.msg-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.65;
  margin-bottom: 8rpx;

  /* 最多显示 2 行 */
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.msg-time {
  font-size: 24rpx;
  color: #bbb;
}

/* 空态（去掉图标，只留文字） */
.empty-wrap {
  padding: 20rpx 0;
  text-align: center;
}

.empty-text {
  color: #bbb;
  font-size: 24rpx;
}
