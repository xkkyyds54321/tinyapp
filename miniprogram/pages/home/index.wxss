/* pages/home/index.wxss */

/* 大背景封面 */
.cover-wrap {
  position: relative;
  width: 100%;
  height: 360rpx;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  background: #fce4ec;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.cover-change-hint {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(0, 0, 0, 0.35);
  border-radius: 30rpx;
  padding: 8rpx 18rpx;
}

.cover-camera-icon {
  font-size: 28rpx;
}

.cover-hint-text {
  font-size: 22rpx;
  color: #fff;
}

.cover-uploading {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
}

/* 情侣信息头部 */
.couple-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(255, 126, 179, 0.08);
}

.couple-user {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.couple-name {
  font-size: 26rpx;
  color: #666;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.couple-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.heart-icon {
  font-size: 48rpx;
}

.together-days {
  font-size: 22rpx;
  color: #ff7eb3;
  font-weight: 500;
  text-decoration: underline;
}

.together-days-tap {
  text-decoration: underline;
  color: #bbb;
}

.days-arrow {
  font-size: 22rpx;
  color: #ff7eb3;
  margin-left: 2rpx;
}

.section-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

/* 照片网格 */
.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
}

.photo-thumb {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 8rpx;
  background: #f5f5f5;
}

/* 纪念日 */
.anniv-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.anniv-item:last-child {
  border-bottom: none;
}

.anniv-title {
  font-size: 28rpx;
  color: #333;
}

.anniv-days {
  font-size: 24rpx;
}

.anniv-days.past {
  color: #ff7eb3;
}

.anniv-days.future {
  color: #6cb0ff;
}

/* 留言 */
.msg-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.msg-item:last-child {
  border-bottom: none;
}

.msg-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.msg-time {
  font-size: 22rpx;
  color: #bbb;
}
