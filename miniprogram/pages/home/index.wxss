/* pages/home/index.wxss */

.page-root {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
}

.bg-image {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.bg-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.18);
  z-index: 1;
}

.change-cover-fab {
  position: fixed;
  right: 28rpx;
  bottom: calc(env(safe-area-inset-bottom) + 430rpx);
  z-index: 10;
  width: 64rpx;
  height: 64rpx;
  background: rgba(0, 0, 0, 0.28);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-fab-icon { font-size: 32rpx; line-height: 1; }
.cover-fab-loading { font-size: 28rpx; color: rgba(255,255,255,0.8); line-height: 1; }

.top-area {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 2;
  padding: 0 28rpx;
  box-sizing: border-box;
}

/* 里程碑横幅 */
.milestone-banner {
  background: rgba(255, 77, 136, 0.88);
  border-radius: 20rpx;
  padding: 16rpx 28rpx;
  margin-top: 16rpx;
  backdrop-filter: blur(8px);
}

.milestone-text {
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.2);
}

/* 纪念日提醒 */
.reminder-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 12rpx;
}

.reminder-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(255, 255, 255, 0.80);
  border-radius: 20rpx;
  padding: 14rpx 22rpx;
  backdrop-filter: blur(8px);
}

.reminder-icon { font-size: 30rpx; flex-shrink: 0; }

.reminder-text {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  flex: 1;
}

/* 功能网格（自适应列数，固定在底部） */
.feature-grid {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: calc(env(safe-area-inset-bottom) + 120rpx);
  z-index: 2;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  gap: 16rpx;
}

.feature-item {
  background: rgba(255, 255, 255, 0.88);
  border-radius: 20rpx;
  padding: 24rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  backdrop-filter: blur(10px);
}

.feature-icon { font-size: 44rpx; line-height: 1; }

.feature-label {
  font-size: 22rpx;
  color: #333;
  font-weight: 500;
  text-align: center;
  word-break: keep-all;
}

/* 情侣头部 */
.couple-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 10rpx 30rpx;
}

.couple-user {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}

.avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: #f5f5f5;
  border: 4rpx solid rgba(255,255,255,0.8);
}

.couple-name {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
  text-shadow: 0 1rpx 6rpx rgba(0,0,0,0.4);
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.couple-id {
  font-size: 18rpx;
  color: rgba(255,255,255,0.65);
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.4);
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.couple-center {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  padding: 0 10rpx;
}

.arc-top {
  width: 100%;
  height: 36rpx;
  border-top: 4rpx solid #ff4d88;
  border-left: 4rpx solid transparent;
  border-right: 4rpx solid transparent;
  border-radius: 50% 50% 0 0 / 100% 100% 0 0;
  box-sizing: border-box;
}

.arc-bottom {
  width: 100%;
  height: 36rpx;
  border-bottom: 4rpx solid #ff4d88;
  border-left: 4rpx solid transparent;
  border-right: 4rpx solid transparent;
  border-radius: 0 0 50% 50% / 0 0 100% 100%;
  box-sizing: border-box;
}

.center-text-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 0;
}

.heart-icon { font-size: 40rpx; }

.together-days {
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
  text-shadow: 0 1rpx 6rpx rgba(0,0,0,0.4);
  text-decoration: underline;
  text-underline-offset: 4rpx;
}

.together-days-tap {
  color: rgba(255,255,255,0.7);
  text-decoration: underline;
}

.loading-wrap, .error-wrap {
  padding: 40rpx 0;
  text-align: center;
}

.loading-text, .error-text {
  color: rgba(255,255,255,0.85);
  font-size: 28rpx;
}
