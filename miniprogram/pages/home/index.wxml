<!-- pages/home/index.wxml -->
<view class="page-root">

  <!-- 全屏背景图 -->
  <image class="bg-image" src="{{couple.coverFileID || '/assets/default-cover.png'}}" mode="aspectFill" />
  <view class="bg-mask" />

  <!-- 右下角换封面小图标 -->
  <view class="change-cover-fab" bindtap="onChangeCover">
    <text class="{{changingCover ? 'cover-fab-loading' : 'cover-fab-icon'}}">{{changingCover ? '…' : '📷'}}</text>
  </view>

  <!-- 情侣头部区（顶部固定区） -->
  <view class="top-area" style="padding-top: calc({{statusBarHeight}}px + 60rpx)">

    <!-- 加载态 -->
    <view class="loading-wrap" wx:if="{{loading}}">
      <view class="loading-text">加载中...</view>
    </view>

    <!-- 错误态 -->
    <view class="error-wrap" wx:elif="{{error}}">
      <view class="error-text">{{error}}</view>
      <button class="btn-secondary" bindtap="loadData" style="width:240rpx">重试</button>
    </view>

    <!-- 情侣信息头部 -->
    <view wx:else class="couple-header">
      <view class="couple-user">
        <image class="avatar" src="{{user.avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill" />
        <view class="couple-name">{{user.nickname || '我'}}</view>
        <view class="couple-id">ID: {{user.openid ? user.openid.slice(-6) : '------'}}</view>
      </view>

      <view class="couple-center" bindtap="goDetail">
        <view class="arc-top" />
        <view class="center-text-wrap">
          <view class="heart-icon">💕</view>
          <view wx:if="{{couple.boundAt}}" class="together-days">在一起 {{togetherDays}} 天 ›</view>
          <view wx:else class="together-days together-days-tap">设置日期 ›</view>
        </view>
        <view class="arc-bottom" />
      </view>

      <view class="couple-user">
        <image class="avatar" src="{{partner.avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill" />
        <view class="couple-name">{{partner.nickname || 'TA'}}</view>
        <view class="couple-id">ID: {{partner.openid ? partner.openid.slice(-6) : '------'}}</view>
      </view>
    </view>
  </view>

  <!-- 底部功能网格（2×2） -->
  <view class="feature-grid" wx:if="{{!loading && !error}}">
    <view class="feature-item" bindtap="goTrack">
      <text class="feature-icon">📍</text>
      <text class="feature-label">情侣轨迹</text>
    </view>
    <view class="feature-item" bindtap="goQuiz">
      <text class="feature-icon">💬</text>
      <text class="feature-label">甜蜜问答</text>
    </view>
    <view class="feature-item" bindtap="goBucket">
      <text class="feature-icon">✅</text>
      <text class="feature-label">100件小事</text>
    </view>
    <view class="feature-item" bindtap="goLetters">
      <text class="feature-icon">💌</text>
      <text class="feature-label">未来情书</text>
    </view>
  </view>

</view>
