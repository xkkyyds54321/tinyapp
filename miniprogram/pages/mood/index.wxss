/* pages/mood/index.wxss */

.mood-input-card {
  margin-bottom: 20rpx;
}

.input-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.emoji-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.emoji-item {
  font-size: 48rpx;
  text-align: center;
  padding: 12rpx 0;
  border-radius: 16rpx;
  border: 3rpx solid transparent;
  transition: all 0.15s;
}

.emoji-selected {
  border-color: #ff7eb3;
  background: #fff0f5;
  transform: scale(1.15);
}

.content-input {
  width: 100%;
  min-height: 80rpx;
  font-size: 28rpx;
  color: #333;
  border: 1rpx solid #f0f0f0;
  border-radius: 12rpx;
  padding: 16rpx;
  box-sizing: border-box;
  background: #fafafa;
  margin-bottom: 24rpx;
}

.submit-btn {
  width: 100%;
}

/* 历史记录 */
.date-group { margin-bottom: 8rpx; }

.date-label {
  font-size: 24rpx;
  color: #aaa;
  padding: 16rpx 32rpx 8rpx;
}

.mood-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 0 0 4rpx;
}

.mood-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-radius: 20rpx;
}

.mood-main {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  flex: 1;
}

.mood-emoji { font-size: 52rpx; line-height: 1; flex-shrink: 0; }

.mood-body { flex: 1; min-width: 0; }

.mood-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.mood-who {
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 24rpx;
  padding: 2rpx 14rpx;
}

.mood-mine { background: #fff0f5; color: #ff4d88; }
.mood-partner { background: #f0f4ff; color: #5b7cf7; }

.mood-time { font-size: 22rpx; color: #ccc; }

.mood-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.5;
  word-break: break-all;
}

.mood-delete {
  color: #ddd;
  font-size: 40rpx;
  line-height: 1;
  padding: 0 4rpx;
  flex-shrink: 0;
}

.load-more {
  text-align: center;
  padding: 32rpx;
  color: #bbb;
  font-size: 26rpx;
}
