/* pages/messages/index.wxss */
.msg-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #fff5f8;
}

.msg-list {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx;
}

.msg-bubble {
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
}

.msg-bubble.mine {
  align-items: flex-end;
}

.msg-bubble.theirs {
  align-items: flex-start;
}

.bubble-content {
  max-width: 80%;
  padding: 20rpx 28rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  line-height: 1.5;
  word-break: break-all;
}

.mine .bubble-content {
  background: linear-gradient(135deg, #ff7eb3, #ff4785);
  color: #fff;
  border-radius: 20rpx 4rpx 20rpx 20rpx;
}

.theirs .bubble-content {
  background: #fff;
  color: #333;
  border-radius: 4rpx 20rpx 20rpx 20rpx;
}

.bubble-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
  padding: 0 8rpx;
}

.bubble-time {
  font-size: 22rpx;
  color: #bbb;
}

.delete-btn {
  font-size: 22rpx;
  color: #f56;
}

/* 输入栏 */
.input-bar {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
}

.msg-input {
  flex: 1;
  background: #f7f7f7;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  font-size: 30rpx;
  color: #333;
  min-height: 72rpx;
  max-height: 200rpx;
}

.send-btn {
  background: linear-gradient(135deg, #ff7eb3, #ff4785);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  padding: 0 28rpx;
  flex-shrink: 0;
  min-width: 0;
}

.send-btn::after {
  border: none;
}

.send-btn[disabled] {
  opacity: 0.5;
}

.load-more {
  text-align: center;
  padding: 20rpx;
  color: #bbb;
  font-size: 24rpx;
}
