/* pages/messages/index.wxss */
.msg-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #fff5f8;
}

.msg-list {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx 24rpx 16rpx;
}

/* ── 每条消息行 ── */
.msg-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 36rpx;
  gap: 16rpx;
}

.msg-row.mine {
  flex-direction: row-reverse;
}

.msg-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #ffd6e7;
}

/* 昵称+时间+气泡 竖向排列 */
.msg-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

/* 昵称+时间 行 */
.msg-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.meta-left {
  flex-direction: row;
}

.meta-right {
  flex-direction: row-reverse;
}

.msg-name {
  font-size: 22rpx;
  color: #aaa;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.msg-time {
  font-size: 22rpx;
  color: #ccc;
}

/* 气泡行（含删除按钮） */
.bubble-wrap {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
}

.bubble-right {
  flex-direction: row-reverse;
}

.bubble-left {
  flex-direction: row;
}

.bubble-content {
  max-width: 72%;
  padding: 20rpx 28rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  line-height: 1.55;
  word-break: break-all;
}

.bubble-content.mine {
  background: linear-gradient(135deg, #ff7eb3, #ff4785);
  color: #fff;
  border-radius: 20rpx 4rpx 20rpx 20rpx;
}

.bubble-content.theirs {
  background: #fff;
  color: #333;
  border-radius: 4rpx 20rpx 20rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.delete-btn {
  font-size: 22rpx;
  color: #f56;
  padding-bottom: 4rpx;
}

/* 输入栏 */
.input-bar {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
}

.msg-input {
  flex: 1;
  background: #f7f7f7;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  font-size: 30rpx;
  color: #333;
  min-height: 72rpx;
  max-height: 200rpx;
}

.send-btn {
  background: linear-gradient(135deg, #ff7eb3, #ff4785);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  padding: 0 28rpx;
  flex-shrink: 0;
  min-width: 0;
}

.send-btn::after {
  border: none;
}

.send-btn[disabled] {
  opacity: 0.5;
}

.load-more {
  text-align: center;
  padding: 16rpx;
  color: #bbb;
  font-size: 24rpx;
}
