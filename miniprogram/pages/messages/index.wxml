<!-- pages/messages/index.wxml -->
<view class="msg-page">

  <view class="loading-wrap" wx:if="{{loading && !list.length}}">
    <view class="loading-text">加载中...</view>
  </view>

  <view class="empty-wrap" wx:elif="{{!list.length}}">
    <view class="empty-icon">💌</view>
    <view class="empty-text">还没有留言</view>
    <view class="empty-sub">和 TA 说点什么吧</view>
  </view>

  <scroll-view class="msg-list" scroll-y wx:else>
    <view
      class="msg-bubble {{item.isMine ? 'mine' : 'theirs'}}"
      wx:for="{{list}}"
      wx:key="_id"
    >
      <view class="bubble-content">{{item.content}}</view>
      <view class="bubble-meta">
        <text class="bubble-time">{{item.timeLabel}}</text>
        <text class="delete-btn" wx:if="{{item.isMine}}" bindtap="onDelete" data-id="{{item._id}}"> 删除</text>
      </view>
    </view>

    <view class="load-more" wx:if="{{hasMore}}" bindtap="loadMore">
      <text wx:if="{{loadingMore}}">加载中...</text>
      <text wx:else>加载更多</text>
    </view>
  </scroll-view>

  <!-- 输入框 -->
  <view class="input-bar">
    <textarea
      class="msg-input"
      placeholder="说点什么..."
      value="{{inputText}}"
      bindinput="onInput"
      maxlength="300"
      auto-height
      confirm-type="send"
    />
    <button
      class="send-btn"
      bindtap="onSend"
      disabled="{{!inputText.trim()}}"
      loading="{{sending}}"
    >发送</button>
  </view>

</view>
