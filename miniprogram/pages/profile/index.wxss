/* pages/profile/index.wxss */
.user-card {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.profile-sub {
  font-size: 24rpx;
  color: #aaa;
}

.couple-info-row, .storage-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.couple-info-row:last-child, .storage-row:last-child {
  border-bottom: none;
}

.ci-label, .st-label {
  font-size: 28rpx;
  color: #999;
}

.ci-value, .st-value {
  font-size: 28rpx;
  color: #333;
}

.ci-value.bound {
  color: #ff7eb3;
}

/* 菜单 */
.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.menu-label {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  color: #ccc;
  font-size: 32rpx;
}

.version-hint {
  text-align: center;
  color: #ccc;
  font-size: 22rpx;
  padding: 40rpx 0 20rpx;
}
