/* pages/profile/index.wxss */
.user-card {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

/* 头像按钮 */
.avatar-btn {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  flex-shrink: 0;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: block;
}

.avatar-edit-hint {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0,0,0,0.4);
  color: #fff;
  font-size: 18rpx;
  text-align: center;
  padding: 4rpx 0;
  border-radius: 0 0 60rpx 60rpx;
}

.profile-info {
  flex: 1;
}

.nickname-row {
  margin-bottom: 8rpx;
}

.nickname-input {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  width: 100%;
  border-bottom: 2rpx solid #ffe0ef;
  padding-bottom: 4rpx;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.profile-sub {
  font-size: 24rpx;
  color: #aaa;
}

.couple-info-row, .storage-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.couple-info-row:last-child, .storage-row:last-child {
  border-bottom: none;
}

.ci-label, .st-label {
  font-size: 28rpx;
  color: #999;
}

.ci-value, .st-value {
  font-size: 28rpx;
  color: #333;
}

.ci-value.bound {
  color: #ff7eb3;
}

/* 菜单 */
.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.menu-label {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  color: #ccc;
  font-size: 32rpx;
}

.version-hint {
  text-align: center;
  color: #ccc;
  font-size: 22rpx;
  padding: 40rpx 0 20rpx;
}


