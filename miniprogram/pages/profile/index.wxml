<!-- pages/profile/index.wxml -->
<view class="container">

  <!-- 用户信息（点击头像换微信头像，右侧昵称可编辑） -->
  <view class="card user-card">
    <!-- 我 -->
    <view class="user-block">
      <view class="avatar-wrap">
        <image class="profile-avatar" src="{{user.avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill" />
        <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar" />
      </view>
      <input
        class="nickname-input"
        type="nickname"
        value="{{nicknameInput}}"
        placeholder="设置昵称"
        maxlength="12"
        bindinput="onNicknameInput"
        bindchange="onNicknameChange"
        bindblur="onNicknameBlur"
        confirm-type="done"
        bindconfirm="onNicknameConfirm"
      />
    </view>

    <!-- 连线 + 爱心（双弧线） -->
    <view class="user-connector" wx:if="{{partner && partner.openid}}">
      <view class="conn-arc-top" />
      <view class="conn-center">
        <text class="connector-heart">💕</text>
      </view>
      <view class="conn-arc-bottom" />
    </view>

    <!-- TA -->
    <view class="user-block" wx:if="{{partner && partner.openid}}" bindtap="onViewPartner">
      <view class="avatar-wrap partner-avatar-wrap">
        <image class="profile-avatar" src="{{partner.avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill" />
      </view>
      <view class="partner-nickname">{{partner.nickname || 'TA'}}</view>
    </view>
  </view>

  <!-- 情侣信息 -->
  <view class="card" wx:if="{{couple && couple.status === 'active'}}">
    <view class="section-title">情侣空间</view>
    <view class="couple-info-row">
      <text class="ci-label">状态</text>
      <text class="ci-value bound">已绑定 💕</text>
    </view>
    <view class="couple-info-row">
      <text class="ci-label">绑定时间</text>
      <text class="ci-value">{{boundAtText}}</text>
    </view>
    <view class="couple-info-row">
      <text class="ci-label">在一起</text>
      <text class="ci-value">{{togetherDays}} 天</text>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="card">
    <view class="section-title">功能</view>

    <view class="menu-item" bindtap="goRecycle">
      <text class="menu-icon">🗑️</text>
      <text class="menu-label">照片回收站</text>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" bindtap="onExport">
      <text class="menu-icon">📦</text>
      <text class="menu-label">导出我的数据</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 存储占用 -->
  <view class="card" wx:if="{{storageInfo}}">
    <view class="section-title">存储概览</view>
    <view class="storage-row">
      <text class="st-label">照片总数</text>
      <text class="st-value">{{storageInfo.total}} 张</text>
    </view>
    <view class="storage-row">
      <text class="st-label">回收站</text>
      <text class="st-value">{{storageInfo.deleted}} 张</text>
    </view>
  </view>

  <view class="version-hint">情侣空间 v1.0.0</view>

  <!-- 情侣信息弹窗 -->
  <view class="modal-mask" wx:if="{{showPartnerModal}}" bindtap="onClosePartnerModal">
    <view class="modal-box" catchtap="">
      <view class="modal-title">TA 的信息</view>
      <view class="partner-modal-body">
        <view class="partner-modal-avatar-wrap">
          <image class="partner-modal-avatar" src="{{partner.avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill" />
        </view>
        <view class="partner-modal-name">{{partner.nickname || 'TA'}}</view>
        <view class="partner-modal-row" wx:if="{{couple && couple.boundAt}}">
          <text class="partner-modal-label">在一起</text>
          <text class="partner-modal-value">{{togetherDays}} 天</text>
        </view>
        <view class="partner-modal-row" wx:if="{{boundAtText}}">
          <text class="partner-modal-label">从</text>
          <text class="partner-modal-value">{{boundAtText}}</text>
        </view>
      </view>
      <button class="partner-modal-close-btn" bindtap="onClosePartnerModal">关闭</button>
    </view>
  </view>

</view>
