/* pages/gallery/index.wxss */
.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.filter-btn {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 32rpx;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #666;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.filter-arrow {
  margin-left: 8rpx;
  font-size: 20rpx;
  color: #aaa;
}

.toolbar-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.recycle-btn {
  font-size: 24rpx;
  color: #999;
  background: #fff;
  border-radius: 32rpx;
  padding: 12rpx 20rpx;
}

.upload-btn {
  background: linear-gradient(135deg, #ff7eb3, #ff4785);
  color: #fff;
  border: none;
  border-radius: 32rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 28rpx;
  padding: 0 28rpx;
  min-width: 0;
}

.upload-btn::after {
  border: none;
}

/* 进度条 */
.progress-bar {
  background: #f5f5f5;
  border-radius: 8rpx;
  height: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  position: relative;
}

.progress-fill {
  background: linear-gradient(90deg, #ff7eb3, #ff4785);
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.2s;
}

.progress-text {
  position: absolute;
  top: 0;
  right: 8rpx;
  font-size: 20rpx;
  color: #666;
  line-height: 16rpx;
}

/* 照片网格 */
.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 6rpx;
}

.photo-item {
  position: relative;
  aspect-ratio: 1;
}

.photo-img {
  width: 100%;
  height: 100%;
  border-radius: 4rpx;
  background: #f0f0f0;
}

.photo-time {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.4));
  color: #fff;
  font-size: 18rpx;
  padding: 4rpx 8rpx;
  border-radius: 0 0 4rpx 4rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx;
  color: #bbb;
  font-size: 26rpx;
}
