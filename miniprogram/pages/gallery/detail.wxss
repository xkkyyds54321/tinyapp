/* pages/gallery/detail.wxss */
.detail-container {
  min-height: 100vh;
  background: #111;
}

.detail-img {
  width: 100%;
  height: 60vh;
  background: #222;
}

.detail-info {
  background: #fff;
  margin: 0;
  border-radius: 0;
  padding: 32rpx 40rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  color: #999;
  font-size: 28rpx;
}

.info-value {
  color: #333;
  font-size: 28rpx;
}

.detail-actions {
  padding: 32rpx 40rpx;
  background: #fff;
}

.danger-btn {
  color: #f56;
  border-color: #f56;
}
