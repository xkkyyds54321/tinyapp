/* pages/track/index.wxss */
.container {
  position: relative;
  width: 100vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 2rpx solid #f0f0f0;
  z-index: 10;
  flex-shrink: 0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 30rpx;
  color: #999;
  position: relative;
}

.tab-item.active {
  color: #ff7eb3;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #ff7eb3;
  border-radius: 2rpx;
}

.map {
  flex: 1;
  width: 100%;
}

.info-overlay {
  position: absolute;
  bottom: calc(env(safe-area-inset-bottom) + 40rpx);
  left: 28rpx;
  right: 28rpx;
  background: rgba(255,255,255,0.92);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.12);
  z-index: 10;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.info-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.info-dot.partner { background: #a78bfa; }
.info-dot.waiting { background: #faad14; }
.info-dot.error { background: #ff4d4f; }

.info-text { font-size: 28rpx; color: #333; }
