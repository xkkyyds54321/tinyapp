<!-- pages/couple-detail/index.wxml -->
<view class="container">

  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="loading-text">加载中...</view>
  </view>

  <block wx:else>

    <!-- 双方头像 + 昵称 -->
    <view class="card header-card">
      <view class="couple-user">
        <image class="avatar" src="{{user.avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill" />
        <view class="couple-name">{{user.nickname || '我'}}</view>
      </view>
      <view class="center-block">
        <view class="heart-icon">💕</view>
        <view class="days-big">{{togetherDays}}</view>
        <view class="days-label">天</view>
      </view>
      <view class="couple-user">
        <image class="avatar" src="{{partner.avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill" />
        <view class="couple-name">{{partner.nickname || 'TA'}}</view>
      </view>
    </view>

    <!-- 在一起起始日期（可编辑） -->
    <view class="card date-card">
      <view class="date-label">在一起的第一天</view>
      <picker mode="date" value="{{boundAtDate}}" bindchange="onBoundAtChange">
        <view class="date-row">
          <text class="date-value">{{boundAtDate || '点击设置日期'}}</text>
          <text class="date-edit">✏️ 修改</text>
        </view>
      </picker>
    </view>

    <!-- 纪念日列表 -->
    <view class="card">
      <view class="section-row">
        <view class="section-title">纪念日</view>
        <view class="add-btn" bindtap="onAdd">+ 添加</view>
      </view>

      <view class="empty-wrap" wx:if="{{!anniversaries.length}}">
        <view class="empty-icon">🗓️</view>
        <view class="empty-text">还没有纪念日，点击添加吧</view>
      </view>

      <view wx:else>
        <view class="anniv-item" wx:for="{{anniversaries}}" wx:key="_id">
          <view class="anniv-main">
            <view class="anniv-title">{{item.title}}</view>
            <view class="anniv-date">{{item.date}}</view>
          </view>
          <view class="anniv-days {{item.days >= 0 ? 'past' : 'future'}}">{{item.label}}</view>
          <view class="anniv-actions">
            <text class="action-btn" bindtap="onEdit" data-item="{{item}}">编辑</text>
            <text class="action-btn del" bindtap="onDelete" data-id="{{item._id}}">删除</text>
          </view>
        </view>
      </view>
    </view>

  </block>

  <!-- 添加/编辑纪念日弹窗 -->
  <view class="modal-mask" wx:if="{{showAddModal}}" bindtap="onModalClose" />
  <view class="modal-box" wx:if="{{showAddModal}}">
    <view class="modal-title">{{editId ? '编辑纪念日' : '添加纪念日'}}</view>

    <view class="form-item">
      <view class="form-label">标题</view>
      <input class="form-input" placeholder="如：第一次见面" value="{{form.title}}" bindinput="onFormTitle" />
    </view>

    <view class="form-item">
      <view class="form-label">日期</view>
      <picker mode="date" value="{{form.date}}" bindchange="onFormDate">
        <view class="form-picker">{{form.date || '请选择日期'}}</view>
      </picker>
    </view>

    <view class="form-item">
      <view class="form-label">备注（选填）</view>
      <input class="form-input" placeholder="可以写点小故事" value="{{form.remark}}" bindinput="onFormRemark" />
    </view>

    <view class="modal-btns">
      <button class="btn-cancel" bindtap="onModalClose">取消</button>
      <button class="btn-confirm" bindtap="onSubmit" loading="{{submitting}}">保存</button>
    </view>
  </view>

</view>
