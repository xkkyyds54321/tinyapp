/* pages/bucket/index.wxss */
.container { min-height: 100vh; background: #fff5f8; padding-bottom: 60rpx; }

.loading-wrap { padding: 120rpx 0; text-align: center; }

.progress-wrap {
  padding: 32rpx 28rpx 24rpx;
  background: #fff;
  border-bottom: 2rpx solid #f0f0f0;
}

.progress-text { font-size: 28rpx; color: #666; margin-bottom: 16rpx; }
.progress-count { color: #ff7eb3; font-weight: 700; font-size: 32rpx; }

.progress-bar-bg {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #ff7eb3, #ff4d88);
  border-radius: 6rpx;
  transition: width 0.3s;
}

.grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 4rpx;
  padding: 4rpx;
}

.grid-item {
  position: relative;
  aspect-ratio: 1;
  overflow: hidden;
  border-radius: 4rpx;
}

.grid-item.done { background: #333; }
.grid-item.todo {
  background: #f7f7f7;
  display: flex;
  align-items: center;
  justify-content: center;
}

.grid-photo {
  width: 100%;
  height: 100%;
  display: block;
}

.grid-overlay {
  position: absolute;
  inset: 0;
  background: rgba(255,126,179,0.35);
  display: flex;
  align-items: center;
  justify-content: center;
}

.done-icon {
  font-size: 36rpx;
  color: #fff;
  font-weight: 700;
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.3);
}

.grid-text {
  font-size: 20rpx;
  color: #999;
  text-align: center;
  padding: 8rpx;
  line-height: 1.4;
  word-break: break-all;
}

/* Panel */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.45);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.panel-box {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 48rpx 40rpx calc(env(safe-area-inset-bottom) + 48rpx);
  box-sizing: border-box;
  max-height: 90vh;
  overflow-y: auto;
}

.panel-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
  margin-bottom: 32rpx;
}

.panel-photo {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  display: block;
  margin-bottom: 24rpx;
}

.panel-meta { font-size: 28rpx; color: #666; margin-bottom: 12rpx; }
.panel-desc { font-size: 30rpx; color: #444; line-height: 1.7; margin: 16rpx 0 32rpx; }

.photo-picker {
  width: 100%;
  height: 360rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  background: #f7f7f7;
}

.photo-preview { width: 100%; height: 100%; display: block; }

.photo-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.photo-icon { font-size: 64rpx; margin-bottom: 16rpx; }
.photo-hint { font-size: 28rpx; color: #bbb; }

.input-wrap { margin-bottom: 20rpx; }

.input-field {
  width: 100%;
  background: #f7f7f7;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
}

.date-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #f7f7f7;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.picker-placeholder { color: #bbb; font-size: 30rpx; }
.picker-arrow { color: #999; font-size: 28rpx; }

.modal-actions { display: flex; gap: 20rpx; margin-top: 16rpx; }

.btn-ghost {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  border: 2rpx solid #ddd;
  background: #fff;
  color: #666;
  font-size: 30rpx;
}

.btn-primary {
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #ff7eb3, #ff4d88);
  color: #fff;
  font-size: 30rpx;
  border: none;
}

.btn-delete {
  width: 100%;
  height: 80rpx;
  border-radius: 40rpx;
  background: #fff;
  color: #ff4d4f;
  font-size: 28rpx;
  border: 2rpx solid #ffccc7;
  margin-top: 24rpx;
}
