/* pages/quiz/index.wxss */
.container { min-height: 100vh; background: #fff5f8; padding-bottom: 60rpx; }

.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 2rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 30rpx;
  color: #999;
  position: relative;
}

.tab-item.active {
  color: #ff7eb3;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #ff7eb3;
  border-radius: 2rpx;
}

.loading-wrap, .empty-wrap { padding: 120rpx 0; text-align: center; }
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 32rpx; color: #999; }
.empty-sub { font-size: 26rpx; color: #ccc; margin-top: 12rpx; }

.question-card {
  margin: 32rpx 28rpx 0;
  padding: 40rpx 36rpx;
  background: linear-gradient(135deg, #ff7eb3, #ff4d88);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(255,126,179,0.3);
}

.question-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.question-text {
  font-size: 34rpx;
  color: #fff;
  font-weight: 600;
  line-height: 1.6;
}

.answer-section { margin: 32rpx 28rpx 0; }

.answer-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.answer-input {
  width: 100%;
  min-height: 200rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 30rpx;
  color: #333;
  line-height: 1.7;
  box-sizing: border-box;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #ccc;
  margin-top: 8rpx;
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #ff7eb3, #ff4d88);
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
  margin-top: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(255,126,179,0.4);
}

.waiting-section { margin: 32rpx 28rpx 0; }

.waiting-tip {
  text-align: center;
  padding: 48rpx 0;
}

.waiting-icon { font-size: 64rpx; margin-bottom: 16rpx; }
.waiting-text { font-size: 32rpx; color: #333; font-weight: 600; }
.waiting-sub { font-size: 26rpx; color: #999; margin-top: 12rpx; }

.reveal-section { margin: 32rpx 28rpx 0; }

.reveal-tip {
  text-align: center;
  font-size: 30rpx;
  color: #ff7eb3;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.answer-pair { display: flex; flex-direction: column; gap: 20rpx; }

.my-answer-box { margin-bottom: 24rpx; }

.answer-box {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.answer-box.mine { border-left: 6rpx solid #ff7eb3; }
.answer-box.partner { border-left: 6rpx solid #a78bfa; }

.answer-box-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.answer-box.mine .answer-box-label { color: #ff7eb3; }
.answer-box.partner .answer-box-label { color: #a78bfa; }

.answer-box-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.7;
}

.history-list { padding: 0 28rpx; }

.history-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-top: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.history-date { font-size: 24rpx; color: #bbb; margin-bottom: 12rpx; }
.history-question { font-size: 30rpx; color: #333; font-weight: 600; line-height: 1.5; margin-bottom: 20rpx; }
.history-answers { display: flex; flex-direction: column; gap: 16rpx; }

.load-more, .no-more {
  text-align: center;
  font-size: 26rpx;
  color: #ccc;
  padding: 32rpx 0;
}
